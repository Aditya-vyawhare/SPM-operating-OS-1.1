# PM OS Scheduler — API Keys
# Copy this to .env and fill in your keys

# Required: Claude API key for running agent commands
ANTHROPIC_API_KEY=sk-ant-...

# Required: Slack Bot User OAuth Token for sending/reading messages
SLACK_BOT_TOKEN=xoxb-...

# Optional: Path to Google OAuth credentials JSON for reading Google Docs
# GOOGLE_CREDENTIALS_PATH=scheduler/credentials.json
